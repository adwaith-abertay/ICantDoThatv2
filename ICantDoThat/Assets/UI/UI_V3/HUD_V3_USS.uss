#DeactivateOxygen > VisualElement {
    opacity: 1;
}

#SIIDConsole .unity-label {
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
    -unity-font-definition: url("project://database/Assets/UI/UI_V3/Assets/PixelOperatorHBSC.ttf?fileID=12800000&guid=d9174a0ac864c5946a3b57670a626d7c&type=3#PixelOperatorHBSC");
    -unity-text-align: middle-left;
    margin-top: 5px;
    margin-right: 5px;
    margin-bottom: 5px;
    margin-left: 5px;
    overflow: hidden;
}
